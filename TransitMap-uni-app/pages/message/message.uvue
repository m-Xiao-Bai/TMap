    min-height: 100vh;
    background: #f7f8fa;
    display: flex;
    flex-direction: column;
}

/* 未读统计 */
.header-card {
    margin: 24rpx 24rpx 0;
    background: linear-gradient(135deg, #1a73e8, #1565c0);
    border-radius: 16rpx;
    padding: 22rpx 20rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-shrink: 0;
}
.hc-left {
    display: flex;
    align-items: center;
    gap: 14rpx;
}
.hc-num-wrap {
    width: 60rpx;
    height: 60rpx;
    background: rgba(255, 255, 255, 0.22);
    border-radius: 16rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}
.hc-num {
    font-size: 30rpx;
    color: #fff;
    font-weight: 800;
}
.hc-text-wrap {
    display: flex;
    flex-direction: column;
}
.hc-title {
    font-size: 26rpx;
    color: #fff;
    font-weight: 700;
}
.hc-sub {
    font-size: 20rpx;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 2rpx;
}
.hc-action {
    background: rgba(255, 255, 255, 0.95);
    padding: 10rpx 22rpx;
    border-radius: 14rpx;
}
.hc-action-text {
    font-size: 22rpx;
    color: #1a73e8;
    font-weight: 700;
}

/* 列表 */
.msg-scroll { flex: 1; }
.msg-list { padding: 16rpx 24rpx 0; }
.msg-item {
    background: #fff;
    border-radius: 16rpx;
    border: 1rpx solid #ebeef5;
    padding: 18rpx 20rpx;
    margin-bottom: 12rpx;
    display: flex;
    gap: 14rpx;
}
.msg-item.unread {
    border-color: #d2e3fc;
    background: #f5f8ff;
}
.msg-icon-col {
    position: relative;
    flex-shrink: 0;
    padding-top: 2rpx;
}
.msg-tag {
    padding: 6rpx 12rpx;
    border-radius: 8rpx;
}
.msg-tag-text {
    font-size: 20rpx;
    font-weight: 700;
}
.msg-unread-dot {
    position: absolute;
    top: -2rpx;
    right: -4rpx;
    width: 12rpx;
    height: 12rpx;
    background: #f43f5e;
    border-radius: 50%;
    border: 2rpx solid #fff;
}
.msg-body {
    flex: 1;
    min-width: 0;
}
.msg-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8rpx;
    gap: 10rpx;
}
.msg-title {
    flex: 1;
    font-size: 28rpx;
    color: #1a1a2e;
    font-weight: 700;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.msg-time {
    font-size: 20rpx;
    color: #909399;
    flex-shrink: 0;
}
.msg-content {
    font-size: 24rpx;
    color: #606266;
    line-height: 1.6;
}

/* 空 / 加载 */
.empty-wrap {
    padding: 60rpx 0;
}
.loading-wrap {
    padding: 60rpx 0;
    text-align: center;
}
.loading-text {
    font-size: 26rpx;
    color: #c0c4cc;
}

/* 联系卡 */
.contact-card {
    margin: 20rpx 24rpx 0;
    background: #fff;
    border-radius: 16rpx;
    border: 1rpx solid #ebeef5;
    padding: 22rpx 24rpx;
}
.contact-header {
    display: flex;
    flex-direction: column;
    gap: 4rpx;
