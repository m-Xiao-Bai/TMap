<template>
    <view class="message-page">
        <!-- 顶部未读统计 -->
        <view class="header-card" v-if="unreadCount > 0">
            <view class="hc-left">
                <view class="hc-num-wrap">
                    <text class="hc-num">{{ unreadCount }}</text>
                </view>
                <view class="hc-text-wrap">
                    <text class="hc-title">条未读消息</text>
                    <text class="hc-sub">查看新通知</text>
                </view>
            </view>
            <view class="hc-action" @tap="handleMarkAllRead">
                <text class="hc-action-text">全部已读</text>
            </view>
        </view>

        <!-- 消息列表 -->
        <scroll-view scroll-y class="msg-scroll">
            <view class="msg-list" v-if="messages.length">
                <view class="msg-item" v-for="msg in messages" :key="msg.id"
                      :class="{ unread: msg.isRead === 0 }"
                      @tap="handleRead(msg)">
                    <view class="msg-icon-col">
                        <view class="msg-tag" :style="{ background: getType(msg.type).bg }">
                            <text class="msg-tag-text" :style="{ color: getType(msg.type).color }">{{ getType(msg.type).text }}</text>
                        </view>
                        <view class="msg-unread-dot" v-if="msg.isRead === 0"></view>
                    </view>
                    <view class="msg-body">
                        <view class="msg-head">
                            <text class="msg-title">{{ msg.title }}</text>
                            <text class="msg-time">{{ formatRelativeTime(msg.createTime) }}</text>
                        </view>
                        <text class="msg-content">{{ msg.content }}</text>
                    </view>
                </view>
            </view>

            <view class="empty-wrap" v-else-if="!loading">
                <empty-state icon="📭" title="暂无消息" sub="您的消息通知会显示在这里" />
            </view>

            <view class="loading-wrap" v-else>
                <text class="loading-text">加载中...</text>
            </view>

            <!-- 联系管理员卡 -->
            <view class="contact-card">
                <view class="contact-header">
                    <text class="contact-title">联系管理员</text>
                    <text class="contact-sub">遇到问题？反馈给我们</text>
                </view>
                <textarea class="contact-input"
                          v-model="contactContent"
                          placeholder="请描述您遇到的问题..."
                          placeholder-style="color:#c0c4cc"
                          maxlength="500"
                          :show-confirm-bar="false"></textarea>
                <view class="contact-footer">
                    <text class="contact-counter">{{ contactContent.length }}/500</text>
                    <view class="contact-btn" :class="{ disabled: !contactContent.trim() || sending }" @tap="handleSendContact">
                        <text class="contact-btn-text">发送</text>
                    </view>
                </view>
            </view>

            <view class="bottom-spacer"></view>
        </scroll-view>
    </view>
</template>

<script>
    import { getMessageList, getMessageUnreadCount, markMessageRead, markAllMessagesRead, sendContactMessage } from '@/api/message'
    import { useUserStore } from '@/store/user'
    import { getMessageType, formatRelativeTime } from '@/utils/format'
    import EmptyState from '@/components/empty-state.uvue'

    const userStore = useUserStore()

    export default {
        components: { EmptyState },
        data() {
            return {
                messages: [], loading: false, page: 1, unreadCount: 0,
                contactContent: '', sending: false, pollTimer: null
            }
        },
        onLoad() {
            this.fetchMessages()
            this.fetchUnread()
            this.pollTimer = setInterval(() => { this.fetchUnread() }, 30000)
        },
        onUnload() {
            if (this.pollTimer) clearInterval(this.pollTimer)
        },
        methods: {
            getType: getMessageType,
            formatRelativeTime,
            async fetchMessages() {
                if (!userStore.isLoggedIn()) return
                this.loading = true
                try {
                    const res = await getMessageList({ page: this.page, size: 20 })
                    if (res.code === 200) this.messages = res.data.records || []
                } catch {} finally { this.loading = false }
            },
            async fetchUnread() {
                if (!userStore.isLoggedIn()) return
                try {
                    const res = await getMessageUnreadCount()
                    if (res.code === 200) this.unreadCount = res.data.count || 0
                } catch {}
            },
            async handleRead(msg) {
                if (msg.isRead === 0) {
                    try {
                        await markMessageRead(msg.id)
                        msg.isRead = 1
                        this.unreadCount = Math.max(0, this.unreadCount - 1)
                    } catch {}
                }
            },
            async handleMarkAllRead() {
                try {
                    await markAllMessagesRead()
                    this.messages.forEach(m => m.isRead = 1)
                    this.unreadCount = 0
                    uni.showToast({ title: '已全部标记为已读', icon: 'success' })
                } catch {}
            },
            async handleSendContact() {
                const content = this.contactContent.trim()
                if (!content) {
                    uni.showToast({ title: '请输入内容', icon: 'none' })
                    return
                }
                if (this.sending) return
                this.sending = true
                try {
                    await sendContactMessage(content)
                    uni.showToast({ title: '消息已发送', icon: 'success' })
                    this.contactContent = ''
                } catch {} finally { this.sending = false }
            }
        }
    }
</script>

<style scoped>
