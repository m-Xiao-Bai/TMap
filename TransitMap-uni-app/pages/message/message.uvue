}

.contact-input {
    width: 100%;
    min-height: 160rpx;
    padding: 16rpx;
    background: #fafbfc;
    border: 1rpx solid #ebeef5;
    border-radius: 12rpx;
    font-size: 26rpx;
    color: #303133;
    box-sizing: border-box;
    margin-bottom: 14rpx;
}
.contact-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.contact-counter {
    font-size: 22rpx;
