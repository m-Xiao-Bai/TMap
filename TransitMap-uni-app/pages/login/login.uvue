    width: 140rpx;
    height: 140rpx;
    background: linear-gradient(135deg, #1a73e8, #1565c0);
    border-radius: 36rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 12rpx 32rpx rgba(26, 115, 232, 0.3);
    margin-bottom: 8rpx;
}
.brand-emoji { font-size: 70rpx; }
