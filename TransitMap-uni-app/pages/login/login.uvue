.form-section {
    margin-bottom: 32rpx;
}
.form-row {
    display: flex;
    align-items: center;
    background: #fafbfc;
    border: 1rpx solid #ebeef5;
    border-radius: 14rpx;
    padding: 0 18rpx;
    margin-bottom: 16rpx;
    gap: 14rpx;
}
.form-icon {
    font-size: 30rpx;
    color: #909399;
    flex-shrink: 0;
}
.form-input {
    flex: 1;
    height: 88rpx;
    font-size: 28rpx;
    color: #303133;
    background: transparent;
}
.form-captcha-row {
    padding-right: 8rpx;
}
.form-captcha-img {
    width: 200rpx;
    height: 64rpx;
    border-radius: 8rpx;
    flex-shrink: 0;
    border: 1rpx solid #ebeef5;
}

.login-btn {
    margin-top: 24rpx;
    height: 96rpx;
    background: #1a73e8;
    border-radius: 16rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 20rpx rgba(26, 115, 232, 0.3);
}
.login-btn.disabled {
    background: #c0c4cc;
    box-shadow: none;
}
.login-btn-text {
    font-size: 32rpx;
    color: #fff;
    font-weight: 700;
    letter-spacing: 8rpx;
}

/* 其他登录 */
.other-section {
    margin-bottom: 28rpx;
}
.divider {
    display: flex;
    align-items: center;
    gap: 18rpx;
    margin-bottom: 24rpx;
}
.divider-line {
    flex: 1;
    height: 1rpx;
    background: #ebeef5;
}
.divider-text {
    font-size: 22rpx;
    color: #909399;
}
.wechat-btn {
    height: 88rpx;
    background: #fff;
    border: 1rpx solid #07c160;
    border-radius: 14rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12rpx;
}
