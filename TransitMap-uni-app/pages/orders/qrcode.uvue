    top: 16rpx; right: 16rpx;
    border-top: 6rpx solid #1a73e8;
    border-right: 6rpx solid #1a73e8;
    border-radius: 0 8rpx 0 0;
}
.qr-corner-bl {
    bottom: 16rpx; left: 16rpx;
    border-bottom: 6rpx solid #1a73e8;
    border-left: 6rpx solid #1a73e8;
    border-radius: 0 0 0 8rpx;
}
