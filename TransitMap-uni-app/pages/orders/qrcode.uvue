    bottom: 16rpx; right: 16rpx;
    border-bottom: 6rpx solid #1a73e8;
    border-right: 6rpx solid #1a73e8;
    border-radius: 0 0 8rpx 0;
}
.qr-image-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
}
.qr-image {
    width: 460rpx;
    height: 460rpx;
}
