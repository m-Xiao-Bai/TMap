    background: #ebeef5;
}

/* 操作 */
.action-row {
    display: flex;
    justify-content: center;
    margin-top: 40rpx;
}
.ar-btn {
    display: flex;
    align-items: center;
    gap: 8rpx;
    padding: 16rpx 36rpx;
    background: #f5f8ff;
    border-radius: 30rpx;
    border: 1rpx solid #d2e3fc;
}
