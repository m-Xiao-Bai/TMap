    width: 560rpx;
    height: 560rpx;
    margin: 0 auto;
    background: #fff;
    border-radius: 24rpx;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.08);
}
.qr-corner {
    position: absolute;
    width: 40rpx;
    height: 40rpx;
}
