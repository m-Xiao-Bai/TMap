.rf-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16rpx;
}
.rf-title {
    font-size: 26rpx;
    color: #303133;
    font-weight: 700;
}
.rf-status {
    background: rgba(245, 158, 11, 0.12);
    padding: 4rpx 12rpx;
    border-radius: 10rpx;
}
.rf-status-text {
    font-size: 20rpx;
    color: #f59e0b;
    font-weight: 700;
}
.rf-status-done {
    background: rgba(244, 63, 94, 0.12);
}
.rf-status-done .rf-status-text {
    color: #f43f5e;
}
.rf-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 8rpx 0;
}
.rf-label {
    font-size: 24rpx;
    color: #909399;
    width: 160rpx;
    flex-shrink: 0;
}
.rf-value {
    font-size: 24rpx;
    color: #303133;
    font-weight: 500;
    flex: 1;
    text-align: right;
}
.rf-hint {
    font-size: 22rpx;
    color: #909399;
    margin-top: 12rpx;
    text-align: center;
    display: block;
    padding: 12rpx 0 0;
    border-top: 1rpx dashed #f0f2f5;
}

.bottom-spacer { height: 40rpx; }

/* 底部操作栏 */
.action-bar {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    background: #fff;
    border-top: 1rpx solid #ebeef5;
    padding: 16rpx 24rpx;
    display: flex;
    gap: 12rpx;
    z-index: 100;
}
.ab-btn {
    flex: 1;
    height: 88rpx;
    border-radius: 14rpx;
    display: flex;
    align-items: center;
    justify-content: center;
}
.ab-btn-primary {
    background: #1a73e8;
}
.ab-btn-text-primary {
    color: #fff;
    font-size: 30rpx;
    font-weight: 700;
}
.ab-btn-ghost {
    background: #fff;
    border: 1rpx solid #ebeef5;
}
.ab-btn-text-ghost {
    color: #606266;
    font-size: 30rpx;
    font-weight: 600;
}
</style>
