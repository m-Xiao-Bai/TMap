<template>
    <view class="orders-page">
        <!-- 顶部统计 -->
        <view class="stats-bar">
            <view class="stat-item">
                <text class="stat-value">{{ orders.length }}</text>
                <text class="stat-label">总订单</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
                <text class="stat-value stat-pending">{{ countByStatus(0) }}</text>
                <text class="stat-label">待支付</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
                <text class="stat-value stat-success">{{ countByStatus(1) }}</text>
                <text class="stat-label">已支付</text>
            </view>
            <view class="stat-divider"></view>
            <view class="stat-item">
                <text class="stat-value">¥{{ totalSpent }}</text>
                <text class="stat-label">总花费</text>
            </view>
        </view>

        <!-- 状态筛选 -->
        <scroll-view scroll-x class="filter-tabs">
            <view class="tab" :class="{ active: filter === '' }" @tap="filter = ''">
                <text class="tab-text">全部</text>
            </view>
            <view class="tab" :class="{ active: filter === '0' }" @tap="filter = '0'">
                <text class="tab-text">待支付</text>
                <view class="tab-dot" v-if="countByStatus(0) > 0"></view>
            </view>
            <view class="tab" :class="{ active: filter === '1' }" @tap="filter = '1'">
                <text class="tab-text">已支付</text>
            </view>
            <view class="tab" :class="{ active: filter === '2' }" @tap="filter = '2'">
                <text class="tab-text">已使用</text>
            </view>
            <view class="tab" :class="{ active: filter === '5' }" @tap="filter = '5'">
                <text class="tab-text">退票审核中</text>
            </view>
            <view class="tab" :class="{ active: filter === '4' }" @tap="filter = '4'">
                <text class="tab-text">已退票</text>
            </view>
            <view class="tab" :class="{ active: filter === '3' }" @tap="filter = '3'">
                <text class="tab-text">已过期</text>
            </view>
        </scroll-view>

        <!-- 订单列表 -->
        <scroll-view scroll-y class="order-scroll" v-if="filteredOrders.length">
            <view class="order-list">
                <view class="ticket-card" v-for="order in filteredOrders" :key="order.id" @tap="goDetail(order)">
                    <!-- 顶部 -->
                    <view class="tc-top">
                        <view class="tc-status-tag" :style="{ background: getStatus(order.status).bg, color: getStatus(order.status).color }">
                            <view class="tc-status-dot" :style="{ background: getStatus(order.status).color }"></view>
                            <text class="tc-status-text" :style="{ color: getStatus(order.status).color }">{{ getStatus(order.status).text }}</text>
                        </view>
                        <text class="tc-no">{{ order.orderNo }}</text>
                    </view>

                    <!-- 起终站 -->
                    <view class="tc-route">
                        <view class="tc-route-side">
                            <text class="tc-route-label">出发</text>
                            <text class="tc-route-name">{{ order.startStationName }}</text>
                        </view>
                        <view class="tc-route-mid">
                            <view class="tc-route-line"></view>
                            <view class="tc-route-badge">
                                <text class="tc-route-badge-text">{{ order.stationCount }}站</text>
                            </view>
                            <view class="tc-route-line"></view>
                        </view>
                        <view class="tc-route-side tc-route-side-end">
                            <text class="tc-route-label">到达</text>
                            <text class="tc-route-name">{{ order.endStationName }}</text>
                        </view>
                    </view>

                    <!-- 撕齿分隔 -->
                    <view class="tc-perf">
                        <view class="tc-perf-circle tc-perf-left"></view>
                        <view class="tc-perf-line"></view>
                        <view class="tc-perf-circle tc-perf-right"></view>
                    </view>

                    <!-- 底部 -->
                    <view class="tc-bottom">
                        <view class="tc-bottom-info">
                            <text class="tc-info-text">{{ formatDate(order.createTime) }}</text>
                            <text class="tc-info-dot">·</text>
                            <text class="tc-info-text">{{ calcMin(order.stationCount) }}分钟</text>
                        </view>
                        <view class="tc-bottom-right">
                            <view class="tc-price">
                                <text class="tc-price-currency">¥</text>
                                <text class="tc-price-value">{{ order.price }}</text>
                            </view>
                            <view class="tc-actions" @tap.stop>
                                <view class="tc-btn tc-btn-primary" v-if="order.status === 0" @tap="handlePay(order)">
                                    <text class="tc-btn-text">支付</text>
                                </view>
                                <view class="tc-btn tc-btn-ghost" v-if="order.status === 0" @tap="handleCancel(order)">
                                    <text class="tc-btn-text-ghost">取消</text>
                                </view>
                                <view class="tc-btn tc-btn-primary" v-if="order.status === 1" @tap="goQrCode(order)">
                                    <text class="tc-btn-text">扫码进站</text>
                                </view>
                                <view class="tc-btn tc-btn-ghost" v-if="order.status === 2" @tap="goDetail(order)">
                                    <text class="tc-btn-text-ghost">查看详情</text>
                                </view>
                            </view>
                        </view>
                    </view>
                </view>
            </view>
            <view class="bottom-spacer"></view>
        </scroll-view>

        <!-- 空态 -->
        <view class="empty-wrap" v-else-if="!loading">
            <empty-state
                :icon="filter === '' ? '🎫' : '🔍'"
                :title="filter === '' ? '还没有订单' : '没有该状态的订单'"
                :sub="filter === '' ? '快去查询路线开启出行吧' : '换个筛选条件试试'"
                :actionText="filter === '' ? '去查询路线' : ''"
                @action="goHome"
            />
        </view>

        <!-- 加载中 -->
        <view class="loading-wrap" v-else>
            <text class="loading-text">加载中...</text>
        </view>
    </view>
</template>

<script>
    import { getMyTicketOrders, payTicketOrder, cancelTicketOrder } from '@/api/ticket'
    import { useUserStore } from '@/store/user'
    import { getOrderStatus, formatDate, formatPrice } from '@/utils/format'
    import { calcMinutes } from '@/utils/config'
    import EmptyState from '@/components/empty-state.uvue'

    const userStore = useUserStore()

    export default {
        components: { EmptyState },
        data() {
            return {
                orders: [], loading: false, filter: '', pollTimer: null
            }
        },
        computed: {
            filteredOrders() {
                if (!this.filter) return this.orders
                return this.orders.filter(o => String(o.status) === this.filter)
            },
            totalSpent() {
                const total = this.orders
                    .filter(o => Number(o.status) === 1 || Number(o.status) === 2)
                    .reduce((sum, o) => sum + Number(o.price || 0), 0)
                return total.toFixed(2)
            }
        },
        onLoad() {
            this.fetchOrders()
            this.pollTimer = setInterval(() => { this.fetchOrders() }, 30000)
        },
        onShow() {
            // 从详情页返回时刷新
            this.fetchOrders()
        },
        onPullDownRefresh() {
            this.fetchOrders().then(() => uni.stopPullDownRefresh())
        },
        onUnload() {
            if (this.pollTimer) clearInterval(this.pollTimer)
        },
        methods: {
            getStatus(s) { return getOrderStatus(s) },
            countByStatus(s) {
                return this.orders.filter(o => Number(o.status) === s).length
            },
            formatDate, formatPrice,
            calcMin(stops) { return calcMinutes(stops || 0) },
            goHome() {
                uni.switchTab({ url: '/pages/index/index' })
            },
            goDetail(order) {
                uni.navigateTo({ url: '/pages/orders/detail?id=' + order.id })
            },
            goQrCode(order) {
                uni.navigateTo({ url: '/pages/orders/qrcode?id=' + order.id })
            },
            async fetchOrders() {
                if (!userStore.isLoggedIn()) {
                    this.orders = []
                    return
                }
                this.loading = true
                try {
                    const res = await getMyTicketOrders()
                    if (res.code === 200) this.orders = res.data || []
                } catch {} finally { this.loading = false }
            },
            handlePay(order) {
                uni.showModal({
                    title: '确认支付', content: `支付 ¥${order.price}？`,
                    success: async (r) => {
                        if (!r.confirm) return
                        try {
                            const res = await payTicketOrder({ orderId: order.id })
                            if (res.code === 200) {
                                uni.showToast({ title: '支付成功', icon: 'success' })
                                this.fetchOrders()
                            }
                        } catch {}
                    }
                })
            },
            handleCancel(order) {
                uni.showModal({
                    title: '取消订单', content: '确定要取消这个订单吗？',
                    success: async (r) => {
                        if (!r.confirm) return
                        try {
                            const res = await cancelTicketOrder({ orderId: order.id })
                            if (res.code === 200) {
                                uni.showToast({ title: '已取消', icon: 'success' })
                                this.fetchOrders()
                            }
                        } catch {
                            uni.showToast({ title: '取消失败', icon: 'none' })
                        }
                    }
                })
            }
        }
    }
</script>

