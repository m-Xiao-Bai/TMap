    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4rpx;
}
.stat-value {
    font-size: 30rpx;
    font-weight: 800;
    color: #1a1a2e;
    line-height: 1.1;
}
.stat-pending { color: #f59e0b; }
.stat-success { color: #1a73e8; }
.stat-label {
    font-size: 20rpx;
    color: #909399;
}
.stat-divider {
    width: 1rpx;
    height: 32rpx;
    background: #ebeef5;
}

