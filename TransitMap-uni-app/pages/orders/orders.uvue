    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 10rpx 22rpx;
    border-radius: 20rpx;
    background: #f5f7fa;
    flex-shrink: 0;
}
.tab.active {
    background: #1a73e8;
}
.tab-text {
    font-size: 24rpx;
    color: #606266;
    font-weight: 600;
}
.tab.active .tab-text { color: #fff; }
.tab-dot {
    position: absolute;
    top: 4rpx; right: 4rpx;
    width: 12rpx; height: 12rpx;
    background: #f43f5e;
    border-radius: 50%;
    border: 2rpx solid #fff;
}

/* 订单滚动区 */
.order-scroll {
    flex: 1;
}
.order-list {
    padding: 16rpx 24rpx 0;
}

/* 车票卡片 */
.ticket-card {
    background: #fff;
