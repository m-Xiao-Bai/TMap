}
.tc-perf-circle {
    width: 24rpx;
    height: 24rpx;
    background: #f7f8fa;
    border-radius: 50%;
    flex-shrink: 0;
}
.tc-perf-left { margin-left: -16rpx; }
.tc-perf-right { margin-right: -16rpx; }
.tc-perf-line {
    flex: 1;
    height: 1rpx;
    background-image: linear-gradient(to right, #d0d7de 50%, transparent 50%);
    background-size: 12rpx 1rpx;
    background-repeat: repeat-x;
}

/* 底部 */
.tc-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14rpx 20rpx 16rpx;
}
