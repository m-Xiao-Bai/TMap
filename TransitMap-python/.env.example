# ══════════════════════════════════════
# TransitMap Python Service — 环境变量配置
# 复制此文件为 .env 并填入实际值
# ══════════════════════════════════════

# ── 服务配置 ──
PYTHON_SERVICE_PORT=8000
PYTHON_SERVICE_HOST=0.0.0.0
PYTHON_SERVICE_API_KEY=your-python-service-api-key
DEBUG=false

# ── 数据库（与 Java 共享 MySQL） ──
DATABASE_URL=mysql+pymysql://root:tmap123@mysql:3306/transit_map
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Java 内部 API ──
JAVA_INTERNAL_API_URL=http://user-server:8888/transitMap/api/internal
JAVA_INTERNAL_API_KEY=internal-shared-secret
JAVA_INTERNAL_TIMEOUT=10

# ── 高德 API ──
AMAP_API_KEY=your-amap-api-key
AMAP_BASE_URL=https://restapi.amap.com

# ── 爬虫配置 ──
CRAWLER_MAX_CONCURRENT=1
CRAWLER_DEFAULT_SOURCES=wikipedia,baike
CRAWLER_GEOCODE_BATCH_SIZE=10
CRAWLER_GEOCODE_DELAY_MS=100

# ── LLM 供应商（支持多个，按序号排列） ──
# 格式: LLM_PROVIDER_{N}_{FIELD}
# N 从 1 开始递增

# 供应商 1（默认）
LLM_PROVIDER_1_NAME=deepseek
LLM_PROVIDER_1_BASE_URL=https://api.deepseek.com/v1
LLM_PROVIDER_1_API_KEY=sk-your-deepseek-key
LLM_PROVIDER_1_MODEL=deepseek-chat
LLM_PROVIDER_1_IS_DEFAULT=true
LLM_PROVIDER_1_MAX_TOKENS=1024
LLM_PROVIDER_1_TEMPERATURE=0.3
LLM_PROVIDER_1_TIMEOUT_MS=30000

# 供应商 2（备用）
# LLM_PROVIDER_2_NAME=qwen
# LLM_PROVIDER_2_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_PROVIDER_2_API_KEY=sk-your-qwen-key
# LLM_PROVIDER_2_MODEL=qwen-plus
# LLM_PROVIDER_2_IS_DEFAULT=false
